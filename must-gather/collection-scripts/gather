#!/bin/bash

# Debug image for oc debug (uses cluster default if not specified)
# To see what image is used, check: oc get node <node> -o jsonpath='{.status.nodeInfo.osImage}'
echo "Starting PTP must-gather..."

# resource list
resources=()
resources+=(ns/openshift-ptp)
resources+=(ns/openshift-marketplace)
resources+=(nodeptpdevices ptpconfigs ptpoperatorconfigs)

# Collect resources
for resource in ${resources[@]}; do
  /usr/bin/oc adm inspect --dest-dir must-gather --all-namespaces ${resource}
done

# --- Capture PTP Announce packets from time-receiver interfaces ---

PTP_CAPTURE_DIR="must-gather/ptp-captures"
mkdir -p "${PTP_CAPTURE_DIR}"

# Get time-receiver node/interface pairs and capture
/usr/bin/oc get ptpconfigs -n openshift-ptp -o json 2>/dev/null | \
  jq -r '.items[] |
    (.spec.profile[]? | select(
      (.ptp4lOpts // "" | test("(^|\\s)-s(\\s|$)")) or 
      (.ptp4lConf // "" | test("slaveOnly\\s+1"; "i"))
    )) as $profile |
    (.status.matchList[]? | select(.profile == $profile.name)) as $match |
    (
      if $profile.interface then [$profile.interface]
      else [$profile.ptp4lConf | scan("\\[([a-zA-Z][a-zA-Z0-9_]+)\\]") | .[0] | select(. != "global")]
      end
    ) | .[] as $iface |
    "\($match.nodeName) \($iface)"
  ' 2>/dev/null | sort -u | while read -r NODE_NAME INTERFACE; do

  [ -z "$NODE_NAME" ] || [ -z "$INTERFACE" ] || [ "$INTERFACE" = "null" ] && continue
  
  OUTPUT_FILE="${PTP_CAPTURE_DIR}/${NODE_NAME}_${INTERFACE}_announce.pcap"
  
  echo "Capturing PTP announce packets: node=${NODE_NAME}, interface=${INTERFACE}"
  
  # Capture packets, then base64 encode for safe transport
  # Note: oc debug without --image uses the node's default debug image
  /usr/bin/oc debug node/"$NODE_NAME" --quiet --image=docker.io/nicolaka/netshoot -- \
    sh -c "tcpdump -i ${INTERFACE} -c 1 -w /tmp/capture.pcap 'ether proto 0x88f7 and (ether[14] & 0x0f == 0x0b)' 2>/dev/null && base64 /tmp/capture.pcap" \
    2>/dev/null | base64 -d > "$OUTPUT_FILE"

done

exit 0
